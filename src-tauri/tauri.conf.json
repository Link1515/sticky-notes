{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sticky Notes",
  "version": "0.1.0",
  "identifier": "com.example.stickynotes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sticky Notes",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
