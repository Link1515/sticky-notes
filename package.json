{
  "name": "sticky-notes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri-safe": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$targetDir = Join-Path $env:TEMP 'sticky-notes-target-dev'; $env:CARGO_TARGET_DIR = $targetDir; $env:CARGO_INCREMENTAL='0'; $env:RUSTFLAGS='-C codegen-units=1'; $env:CARGO_BUILD_JOBS='1'; pnpm tauri dev\"",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^10.1.0",
    "vue-tsc": "^2.2.0"
  }
}
